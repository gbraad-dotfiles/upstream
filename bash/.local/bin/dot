#!/bin/sh
if [ ! -L "${HOME}/.config/dotfiles" ]; then
  export ZDOTDIR="${HOME}/.dotfiles/zsh/"
fi
export COLORTERM=truecolor

# Parse flags
dotfiles="source ${HOME}/.dotfiles/dotfiles.sh && dotfiles source"
zsh_flags=""
has_c_flag=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -l|-i|-s)
      zsh_flags="$zsh_flags $1"
      shift
      ;;
    -c)
      has_c_flag=1
      shift
      # Continue parsing for more flags
      ;;
    *)
      # First non-flag argument
      break
      ;;
  esac
done

if [ "$has_c_flag" -eq 1 ] && [ "$#" -gt 0 ]; then
  # First arg is the command, rest are passed through
  user_cmd="$1"
  shift
  exec zsh $zsh_flags -c "${dotfiles} && { $user_cmd \"\$@\"; }" -- "$@"
elif [ "$#" -eq 0 ]; then
  exec zsh --login
else
 exec zsh -c "${dotfiles} && { \"\$@\"; }" -- "$@"
fi
